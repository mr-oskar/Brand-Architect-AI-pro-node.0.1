# ─────────────────────────────────────────────────────────────────────────────
# Brand Architect AI Pro — Environment Variables
# Copy this file to .env and fill in the values.
#
# On Replit: set secrets in the "Secrets" tab — never commit real keys.
# Locally:   copy to .env → fill in → never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database (Required) ───────────────────────────────────────────────────────
# Option A: External database (Neon, Supabase, etc.) — recommended for Windows/local dev
# EXTERNAL_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
#
# Option B: Local PostgreSQL
# Local:   postgresql://postgres:password@localhost:5432/brandarchitect
# Docker:  postgresql://postgres:postgres@localhost:5432/brandarchitect
# Replit:  DATABASE_URL is set automatically — do not override on Replit.
EXTERNAL_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require


# ── Auth (Required) ───────────────────────────────────────────────────────────
# JWT signing secret — any random string, 32+ characters.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
# WARNING: Changing this invalidates all existing user sessions.
AUTH_JWT_SECRET=change-me-to-a-long-random-secret-string-here


# ── AI Provider (add at least one) ───────────────────────────────────────────
# You can also add keys from the app after first login:
# Admin → API Keys  (only visible to admin users)
#
# Option 1: OpenAI (recommended)
OPENAI_API_KEY=sk-...
#
# Option 2: Google Gemini
# GEMINI_API_KEY=AIza...
#
# Option 3: Custom OpenAI-compatible endpoint (Nano Banana, local LLM, etc.)
# Set both key and base URL from Admin → API Keys in the app.
#
# Note: On Replit, AI_INTEGRATIONS_OPENAI_API_KEY is set automatically.
# You do NOT need to set OPENAI_API_KEY on Replit.


# ── Optional Overrides ────────────────────────────────────────────────────────
# Disable credit system for development (admins are always exempt)
# CREDITS_ENABLED=false

# Override AI text model (default: gpt-4o-mini)
# AI_TEXT_MODEL=gpt-4o-mini

# Override max tokens per AI call (default: 8192)
# AI_MAX_TOKENS=8192

# Override AI temperature 0.0–1.0 (default: 0.7)
# AI_TEMPERATURE=0.7

# Custom CORS origins (comma-separated, for custom domains)
# ALLOWED_ORIGINS=https://mybrand.com,https://www.mybrand.com
